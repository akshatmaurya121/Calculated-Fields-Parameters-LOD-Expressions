      <column caption='Delivery Status' datatype='string' name='[Calculation_1075927115239424]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='if [Delivery_Time_Min] &lt;= 30 then &quot;FAST&quot;&#13;&#10;else &quot;DELAYED&quot;&#13;&#10;END' />
      </column>
      <column caption='Order Type' datatype='string' name='[Calculation_1075927116496897]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='if [Profit] &lt; 0 then &quot;Loss&quot;&#13;&#10;else &quot;Profit&quot;&#13;&#10;end' />
      </column>
      <column caption='Top N Filter' datatype='boolean' name='[Calculation_1075927117791234]' role='measure' type='nominal'>
